# =============================================================================
# PULSE ENVIRONMENT CONFIGURATION
# =============================================================================
# For real Circle Nanopayments, configure the keys below.
# Demo mode (STUB) works without any keys.
# =============================================================================

# ─── Circle Platform ───────────────────────────────────────────────────────
# Keys configured in .env.local - DO NOT COMMIT
# Get from https://console.circle.com
# Required for real nanopayments (not needed for STUB/demo mode)
# CIRCLE_API_KEY=your_circle_api_key_here
# CIRCLE_ENTITY_SECRET=your_entity_secret_here

# ─── Wallet Set ID ──────────────────────────────────────────────────────
# Created in Circle Console → Developer Wallets → Wallet Sets
# Required for creating worker wallets
WORKER_WALLET_SET_ID=your_wallet_set_id_here

# ─── Arc Network (DO NOT CHANGE) ──────────────────────────────────────────
ARC_RPC=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# ─── USDC on Arc Testnet ─────────────────────────────────────────────────
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ─── Circle Gateway ────────────────────────────────────────────────────
GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_DOMAIN=26

# ─── Payment Config ────────────────────────────────────────────────────────
PAYMENT_PER_PING=0.009
PING_INTERVAL_SECONDS=30
DEFAULT_DAILY_CAP_USD=50
DEFAULT_WORKER_HOURLY_RATE_USD=18

# ─── Google Gemini AI (Optional) ──────────────────────────────────────────
# Keys configured in .env.local - DO NOT COMMIT
# Get from https://aistudio.google.com/app/apikey
# Required for AI-powered dynamic pricing
# GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── App Config ────────────────────────────────────────────────────────
CHAIN=ARC-TESTNET
DATABASE_URL=./pulse.db
PORT=3001
JWT_SECRET=pulse-dev-secret-please-change-in-production

# ─── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Demo Mode ─────────────────────────────────────────────────────────
# Set true to simulate payments without Circle API
# Set false when you have real Circle API keys configured
# Now configured in .env.local - DO NOT COMMIT
# STUB_MODE=true
{
  "name": "pulse",
  "version": "1.0.0",
  "description": "Real-time per-second USDC payroll for freelancers on Arc Testnet",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "server": "node --env-file=.env --import=tsx server/index.ts",
    "frontend": "cd frontend && npm run dev",
    "bootstrap": "node --env-file=.env --import=tsx scripts/bootstrap.ts",
    "demo": "node --env-file=.env --import=tsx scripts/demo.ts",
    "demo:fast": "FAST_DEMO=true node --env-file=.env --import=tsx scripts/demo.ts",
    "build": "tsc --project tsconfig.json --skipLibCheck",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.1.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.30.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "uuid": "^9.0.0",
    "viem": "^2.17.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}

# Pulse Environment Variables
# Copy this to .env and fill in your values

# ─── Circle Platform (Required for live payments) ─────────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
WORKER_WALLET_SET_ID=

# ─── Arc Network (Default: Arc Testnet) ──────────────────────────────────────
ARC_RPC=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app
USDC_ADDRESS=0x3600000000000000000000000000000000000000
GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_DOMAIN=26

# ─── Payment Config ────────────────────────────────────────────────────────
PAYMENT_PER_PING=0.009
PING_INTERVAL_SECONDS=30
DEFAULT_DAILY_CAP_USD=50
DEFAULT_WORKER_HOURLY_RATE_USD=18

# ─── Google Gemini AI (Optional) ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── App Config ────────────────────────────────────────────────────────
CHAIN=ARC-TESTNET
DATABASE_URL=./pulse.db
PORT=3001
JWT_SECRET=change-this-in-production

# ─── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Mode ────────────────────────────────────────────────────────
STUB_MODE=true
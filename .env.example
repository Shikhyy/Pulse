# Pulse Environment Configuration
# Copy this to .env and fill in your values

# ─── Circle Platform ───────────────────────────────────────────────────────────
# Get from https://console.circle.com
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_circle_entity_secret_here

# ─── Arc Network Configuration ─────────────────────────────────────────────────
# https://docs.arc.network/arc/tutorials/deploy-on-arc
ARC_RPC=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# USDC on Arc Testnet
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Circle Gateway
GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
GATEWAY_DOMAIN=26

# ─── Wallet IDs (filled by scripts/bootstrap.ts) ──────────────────────────────
CIRCLE_EMPLOYER_WALLET_ID=
CIRCLE_EMPLOYER_WALLET_ADDRESS=
WORKER_WALLET_SET_ID=
WORKER_1_WALLET_ID=
WORKER_1_WALLET_ADDRESS=
WORKER_2_WALLET_ID=
WORKER_2_WALLET_ADDRESS=
WORKER_3_WALLET_ID=
WORKER_3_WALLET_ADDRESS=
WORKER_4_WALLET_ID=
WORKER_4_WALLET_ADDRESS=
WORKER_5_WALLET_ID=
WORKER_5_WALLET_ADDRESS=

# ─── Payment Config ───────────────────────────────────────────────────
PAYMENT_PER_PING=0.009
PING_INTERVAL_SECONDS=30
DEFAULT_DAILY_CAP_USD=50
DEFAULT_WORKER_HOURLY_RATE_USD=18
CHAIN=ARC-TESTNET

# ─── Google Gemini AI (Optional) ─────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=./pulse.db

# ─── Server ───────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=change-this-in-production-abc123xyz

# ─── Frontend ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Demo mode ───────────────────────────────────────────────────────────
# Set to false when Circle API is configured
STUB_MODE=true